{
  "name": "clyde",
  "version": "0.1.6",
  "description": "A desktop pet that reacts to your AI coding agent sessions in real-time.",
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "demo:permissions": "bash scripts/demo-permissions.sh queue",
    "tauri": "tauri",
    "start": "tauri dev",
    "test": "cargo test --manifest-path src-tauri/Cargo.toml && node --test hooks/tests/install-permission-request.test.cjs",
    "test:hooks": "node --test hooks/tests/install-permission-request.test.cjs"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tauri-apps/cli": "^2",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vite-plugin-static-copy": "^2.0.0"
  },
  "dependencies": {
    "@tauri-apps/api": "^2"
  }
}
